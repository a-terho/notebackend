  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "cross-env NODE_ENV=development node --watch index.js",
    "test": "cross-env NODE_ENV=test node --test",
    "lint": "eslint .",
    "build:ui": "rm -rf dist && cd ../notefrontend && npm run build:ui",
    "deploy": "npm run build:ui && git add . && git commit -m autobuild && git push",
